{
    "name": "wp-react",
    "version": "1.0.1",
    "description": "Building React app using WordPress REST API",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "type": "module",
    "files": [
        "dist",
        "README.md",
        "LICENSE",
        "CHANGELOG.md"
    ],
    "bin": {
        "wp-react-cli": "./dist/cli/index.js"
    },
    "scripts": {
        "build": "npm run clean && rollup -c && tsc-alias",
        "postbuild": "chmod +x ./dist/cli/index.js",
        "dev": "rollup -c -w",
        "test": "jest --coverage",
        "update-license-years": "ts-node src/scripts/update-license-years.ts",
        "prepublishOnly": "npm run update-license-years && npm run build && npm run test",
        "lint": "eslint src --ext ts,tsx",
        "format": "prettier --write src",
        "typecheck": "tsc --noEmit",
        "cli": "ts-node src/cli/index.ts",
        "clean": "rm -rf ./dist ./coverage"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/FarahmandM/wp-react.git"
    },
    "keywords": [
        "React",
        "ReactJS",
        "WP",
        "WordPress",
        "API",
        "WordPress API",
        "WP API",
        "REST API",
        "WordPress REST API",
        "WP REST API",
        "WP GraphQL"
    ],
    "author": "Farahmand Moslemi",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/FarahmandM/wp-react/issues"
    },
    "homepage": "https://github.com/FarahmandM/wp-react#readme",
    "peerDependencies": {
        "@tanstack/react-query": "^5.0.0",
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "devDependencies": {
        "@rollup/plugin-alias": "^5.1.1",
        "@rollup/plugin-commonjs": "^28.0.3",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.1",
        "@rollup/plugin-typescript": "^12.1.2",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/dompurify": "^3.2.0",
        "@types/express": "^5.0.3",
        "@types/inquirer": "^9.0.8",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.15.18",
        "@types/react": "^19.1.4",
        "@types/react-dom": "^19.1.5",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "dotenv": "^16.5.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-react": "^7.37.5",
        "express": "^5.1.0",
        "inquirer": "^12.6.3",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^30.4.1",
        "open": "^10.1.2",
        "prettier": "^3.5.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "rollup": "^4.43.0",
        "rollup-plugin-typescript-paths": "^1.5.0",
        "ts-jest": "^29.3.4",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.8",
        "tsconfig-paths": "^4.2.0",
        "tslib": "^2.8.1",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/sdk-trace-web": "^2.0.1",
        "@tanstack/react-query": "^5.0.0",
        "@tanstack/react-query-devtools": "^5.0.0",
        "@types/inquirer": "^9.0.8",
        "axios": "^1.9.0",
        "dompurify": "^3.2.5",
        "graphql-request": "^7.1.2"
    }
}
