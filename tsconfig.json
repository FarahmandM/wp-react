{
    "compilerOptions": {
        "baseUrl": "./src",
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "resolveJsonModule": true,
        "jsx": "react-jsx",
        "rootDir": "./src",
        "outDir": "./dist",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "incremental": true,
        "paths": {
            "@api/*": ["api/*"],
            "@components/*": ["components/*"],
            "@hooks/*": ["hooks/*"],
            "@utils/*": ["utils/*"],
            "@models/*": ["types/*"],
            "@core/*": ["core/*"]
        }
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "examples",
        "coverage"
    ]
}